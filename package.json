{
  "name": "mtg-proxy-maker",
  "description": "Declarative CLI to generate high-quality MTG proxy card PDFs from YAML/JSON deck files",
  "version": "2.0.0",
  "type": "module",
  "bin": {
    "mtg-proxy": "dist/index.js"
  },
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm --target node20 --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "playwright": "^1.52.0",
    "ts-pattern": "^4.2.2",
    "yaml": "^2.7.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3"
  }
}
